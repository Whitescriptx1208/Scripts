local function EnableNoclip()
    if NoclipActive then return end
    NoclipActive = true
    NoclipConnection = RunService.RenderStepped:Connect(function()
        if player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
            for _, v in pairs(player.Character:GetDescendants()) do
                if v:IsA("BasePart") and v.CanCollide then
                    v.CanCollide = false
                end
            end
        end
    end)
end

local function DisableNoclip()
    NoclipActive = false
    if NoclipConnection then
        NoclipConnection:Disconnect()
        NoclipConnection = nil
    end
    if player.Character then
        for _, v in pairs(player.Character:GetDescendants()) do
            if v:IsA("BasePart") then
                v.CanCollide = true
            end
        end
    end
end

-------------------------------------------------
-- FLY SYSTEM
-------------------------------------------------
local function CreateFly()
    local char = player.Character
    if not char then return nil, nil end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return nil, nil end
    
    local humanoid = char:FindFirstChild("Humanoid")
    if humanoid then
        humanoid.WalkSpeed = 0
        humanoid.JumpPower = 0
        humanoid.AutoRotate = false
        humanoid.PlatformStand = true
    end
    
    for _, v in pairs(hrp:GetChildren()) do
        if v:IsA("BodyVelocity") or v:IsA("BodyGyro") or v:IsA("BodyPosition") then
            v:Destroy()
        end
    end
    
    local bv = Instance.new("BodyVelocity")
    bv.MaxForce = Vector3.new(9999999, 9999999, 9999999)
    bv.Velocity = Vector3.new(0, 0, 0)
    bv.P = 100000
    bv.Name = "FlyVelocity"
    bv.Parent = hrp
    
    local bg = Instance.new("BodyGyro")
    bg.MaxTorque = Vector3.new(9999999, 9999999, 9999999)
    bg.P = 100000
    bg.D = 1000
    bg.CFrame = hrp.CFrame
    bg.Name = "FlyGyro"
    bg.Parent = hrp
    
    return bv, bg
end

local function CleanFly()
    if player.Character then
        local humanoid = player.Character:FindFirstChild("Humanoid")
        if humanoid then
            humanoid.WalkSpeed = 16
            humanoid.JumpPower = 50
            humanoid.AutoRotate = true
            humanoid.PlatformStand = false
        end
        
        local hrp = player.Character:FindFirstChild("HumanoidRootPart")
        if hrp then
            for _, v in pairs(hrp:GetChildren()) do
                if v:IsA("BodyPosition") or v:IsA("BodyVelocity") or v:IsA("BodyGyro") then
                    v:Destroy()
                end
            end
        end
    end
    
    Flying = false
    CurrentTarget = nil
    IsAtSafeHeight = false
    
    if FlyConnection then
        FlyConnection:Disconnect()
        FlyConnection = nil
    end
    
    if SafeHeightConnection then
        SafeHeightConnection:Disconnect()
        SafeHeightConnection = nil
    end
end

-------------------------------------------------
-- FLY TO SAFE HEIGHT - KHÔNG GIỚI HẠN THỜI GIAN
-------------------------------------------------
local function FlyToSafeHeightNoPlayers()
    if not AutoSafeHeight then return end
    if SafeModeActive then return end
    if IsAtSafeHeight then return end
    
    print("🏔️ No players detected - Flying to safe height indefinitely")
    IsAtSafeHeight = true
    CurrentTarget = nil
    Flying = false
    
    local char = player.Character
    if not char then 
        IsAtSafeHeight = false
        return 
    end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then 
        IsAtSafeHeight = false
        return 
    end
    
    if FlyConnection then
        FlyConnection:Disconnect()
        FlyConnection = nil
    end
    
    if SafeHeightConnection then
        SafeHeightConnection:Disconnect()
        SafeHeightConnection = nil
    end
    
    local bv, bg = CreateFly()
    if not bv or not bg then 
        IsAtSafeHeight = false
        return 
    end
    
    EnableNoclip()
    
    local targetY = hrp.Position.Y + SafeHeight
    local reachedTarget = false
    
    -- Luôn giữ ở độ cao an toàn, không giới hạn thời gian
    SafeHeightConnection = RunService.Heartbeat:Connect(function()
        if not IsAtSafeHeight then 
            CleanFly()
            DisableNoclip()
            return 
        end
        
        local char = player.Character
        if not char then 
            CleanFly()
            DisableNoclip()
            return 
        end
        
        local hrp = char:FindFirstChild("HumanoidRootPart")
        if not hrp then 
            CleanFly()
            DisableNoclip()
            return 
        end
        
        local bv = hrp:FindFirstChild("FlyVelocity")
        local bg = hrp:FindFirstChild("FlyGyro")
        
        if not bv or not bg then
            bv, bg = CreateFly()
            if not bv or not bg then return end
        end
        
        if not reachedTarget then
            local currentY = hrp.Position.Y
            local heightDiff = targetY - currentY
            
            if heightDiff <= 1 then
                reachedTarget = true
                bv.Velocity = Vector3.new(0, 0, 0)
                bg.CFrame = hrp.CFrame
                print("✅ Reached safe height!")
            else
                local speed = math.min(FlySpeed, heightDiff * 2)
                bv.Velocity = Vector3.new(0, speed, 0)
                bg.CFrame = CFrame.new(hrp.Position, hrp.Position + Vector3.new(0, 1, 0))
            end
        else
            local currentY = hrp.Position.Y
            local drift = targetY - currentY
            
            if math.abs(drift) > 5 then
                bv.Velocity = Vector3.new(0, math.clamp(drift * 2, -50, 50), 0)
            else
                bv.Velocity = Vector3.new(0, 0, 0)
            end
            
            bg.CFrame = CFrame.new(hrp.Position, hrp.Position + Vector3.new(0, 1, 0))
        end
    end)
end

-------------------------------------------------
-- SAFE MODE SYSTEM
-------------------------------------------------
local function FlyToSafeHeight()
    print("🆘 LOW HP - Safe mode activated!")
    SafeModeActive = true
    CurrentTarget = nil
    Flying = false
    IsAtSafeHeight = false
    
    local char = player.Character
    if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    
    if FlyConnection then
        FlyConnection:Disconnect()
        FlyConnection = nil
    end
    
    if SafeHeightConnection then
        SafeHeightConnection:Disconnect()
        SafeHeightConnection = nil
    end
    
    local bv, bg = CreateFly()
    if not bv or not bg then return end
    
    while SafeModeActive and player.Character and player.Character:FindFirstChild("HumanoidRootPart") do
        local humanoid = player.Character:FindFirstChild("Humanoid")
        if not humanoid then break end
        
        local hpPercent = (humanoid.Health / humanoid.MaxHealth) * 100
        
        bv.Velocity = Vector3.new(0, FlySpeed * 0.8, 0)
        bg.CFrame = CFrame.new(hrp.Position, hrp.Position + Vector3.new(0, 1, 0))
        
        if hpPercent >= 90 then
            print("✅ HP recovered: " .. math.floor(hpPercent) .. "%")
            SafeModeActive = false
            bv.Velocity = Vector3.new(0, 0, 0)
            CleanFly()
            ShouldFly = true
            task.wait(0.5)
            break
        end
        
        task.wait()
    end
    
    if not SafeModeActive then
        CleanFly()
        ShouldFly = true
    end
end

local function CheckHPAndSafety()
    if not player.Character then return end
    local humanoid = player.Character:FindFirstChild("Humanoid")
    if not humanoid then return end
    
    local hpPercent = (humanoid.Health / humanoid.MaxHealth) * 100
    
    if hpPercent <= SafeModeHP and not SafeModeActive then
        print("⚠️ LOW HP: " .. math.floor(hpPercent) .. "%")
        if CurrentTarget then
            print("🛑 Stopping hunt to heal!")
        end
        FlyToSafeHeight()
    end
end

-------------------------------------------------
-- TARGET SYSTEM
-------------------------------------------------
function GetTargets()
    if SafeModeActive then return {} end
    
    local list = {}
    for _, v in pairs(Players:GetPlayers()) do
        if v ~= player and not IsIgnored(v) then
            local char = v.Character
            if char then
                local humanoid = char:FindFirstChild("Humanoid")
                local hrp = char:FindFirstChild("HumanoidRootPart")
                
                if humanoid and hrp and humanoid.Health > 0 then
                    local skipTarget = false
                    if Config.Team == "Marines" and v.Team and v.Team.Name == "Marines" then
                        skipTarget = true
                    elseif Config.Team == "Pirates" and v.Team and v.Team.Name == "Pirates" then
                        skipTarget = true
                    end
                    
                    if not skipTarget then
                        table.insert(list, v)
                    end
                elseif humanoid and humanoid.Health <= 0 then
                    AddToIgnored(v)
                end
            end
        end
    end
    return list
end

function GetClosestTarget(targets)
    if #targets == 0 then return nil end
    if not player.Character or not player.Character:FindFirstChild("HumanoidRootPart") then
        return targets[1]
    end
    
    local myPos = player.Character.HumanoidRootPart.Position
    local closest = nil
    local minDist = math.huge
    
    for _, target in pairs(targets) do
        if target.Character and target.Character:FindFirstChild("HumanoidRootPart") then
            local dist = (target.Character.HumanoidRootPart.Position - myPos).Magnitude
            if dist < minDist then
                minDist = dist
                closest = target
            end
        end
    end
    
    return closest
end

-------------------------------------------------
-- FLY TO TARGET
-------------------------------------------------
local function StartFlying(target)
    if SafeModeActive then return end
    
    CleanFly()
    CurrentTarget = target
    Flying = true
    IsAtSafeHeight = false
    StartChaseTimer(target)
    StartChaseTimeoutTracker(target)  -- Bắt đầu theo dõi thời gian chase
    
    if NoClipEnabled then EnableNoclip() end
    
    local targetDied = false
    local targetNotFound = 0
    
    FlyConnection = RunService.Heartbeat:Connect(function()
        CheckHPAndSafety()
        
        if SafeModeActive then
            CleanFly()
            return
        end
        
        if not Flying or not CurrentTarget then return end
        
        if IsIgnored(CurrentTarget) then
            -- Xóa tracker khi target bị ignore
            ChaseTimeoutTracker[CurrentTarget.UserId] = nil
            CleanFly()
            return
        end
        
        local char = player.Character
        if not char then CleanFly(); return end
        
        local hrp = char:FindFirstChild("HumanoidRootPart")
        if not hrp then CleanFly(); return end
        
        local targetChar = CurrentTarget.Character
        if not targetChar then
            targetNotFound = targetNotFound + 1
            if targetNotFound > 10 then
                if not targetDied then
                    AddFailedAttempt(CurrentTarget)
                    targetDied = true
                end
                -- Xóa tracker khi không tìm thấy target
                ChaseTimeoutTracker[CurrentTarget.UserId] = nil
                CleanFly()
                return
            end
            return
        end
        
        targetNotFound = 0
        
        local targetHRP = targetChar:FindFirstChild("HumanoidRootPart")
        if not targetHRP then
            AddFailedAttempt(CurrentTarget)
            ChaseTimeoutTracker[CurrentTarget.UserId] = nil
            CleanFly()
            return
        end
        
        local targetHum = targetChar:FindFirstChild("Humanoid")
        if targetHum and targetHum.Health <= 0 then
            if not targetDied then
                print("💀 Defeated " .. CurrentTarget.Name)
                AddToIgnored(CurrentTarget)
                targetDied = true
                ChaseStartTime[CurrentTarget.UserId] = nil
                ChaseTimeoutTracker[CurrentTarget.UserId] = nil  -- Xóa tracker khi đánh bại
            end
            CleanFly()
            return
        end
        
        local bv = hrp:FindFirstChild("FlyVelocity")
        local bg = hrp:FindFirstChild("FlyGyro")
        
        if not bv or not bg then
            bv, bg = CreateFly()
            if not bv or not bg then return end
        end
        
        local targetPos = targetHRP.Position
        local myPos = hrp.Position
        local direction = (targetPos - myPos)
        local distance = direction.Magnitude
        
        if distance > 0 then
            local velocity = direction.Unit * FlySpeed
            if distance < 10 then
                velocity = direction.Unit * math.min(FlySpeed, distance * 10)
            end
            bv.Velocity = velocity
        end
        
        bg.CFrame = CFrame.new(myPos, targetPos)
        
        if SpectateTarget and targetHum then
            Camera.CameraSubject = targetHum
        end
    end)
end

