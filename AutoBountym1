-------------------------------------------------
-- FORMAT NUMBER
-------------------------------------------------
local function FormatNumber(n)
    n = tonumber(n) or 0
    local s = tostring(n)
    local k
    repeat
        s, k = string.gsub(s, "^(-?%d+)(%d%d%d)", "%1,%2")
    until k == 0
    return s
end

