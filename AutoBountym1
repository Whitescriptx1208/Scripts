task.spawn(function()
    while true do
        if player.Character then
            CheckHPAndSafety()
        end
        
        if SafeModeActive then
            task.wait(1)
            continue
        end
        
        if ShouldFly and player.Character and not SafeModeActive then
            local targets = GetTargets()
            
            if #targets == 0 then
                -- Không có người chơi: Bay lên cao không giới hạn thời gian
                if AutoSafeHeight and not IsAtSafeHeight then
                    CleanFly()
                    FlyToSafeHeightNoPlayers()
                end
                task.wait(2)
            else
                -- Có người chơi: Tự động quay lại săn
                if IsAtSafeHeight then
                    print("🎯 Players detected - Resuming hunt!")
                    IsAtSafeHeight = false
                    CleanFly()
                end
                
                local closestTarget = GetClosestTarget(targets)
                if closestTarget then
                    if not Flying or CurrentTarget ~= closestTarget then
                        -- Nếu đang chase target cũ, xóa tracker của target cũ
                        if CurrentTarget then
                            ChaseTimeoutTracker[CurrentTarget.UserId] = nil
                        end
                        print("🎯 New target: " .. closestTarget.Name)
                        StartFlying(closestTarget)
                    end
                end
            end
        end
        task.wait(0.5)
    end
